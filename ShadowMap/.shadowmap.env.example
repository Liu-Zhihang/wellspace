# ShadowMap machine profile (example)
#
# Usage:
# - Copy to `ShadowMap/.shadowmap.env` (kept local, gitignored), then run scripts normally.
# - Or keep multiple profiles elsewhere and export `SHADOWMAP_ENV_FILE=/path/to/profile.env`.
# - To skip loading any profile (useful when overriding env vars ad-hoc), set `SHADOWMAP_ENV_FILE=/dev/null`.
#
# This file is designed to unify paths and service URLs across machines (e.g. workstation vs server).
#
# NOTE:
# - Do NOT commit `ShadowMap/.shadowmap.env` with real local paths or credentials.

# --- Mobility batch inputs/outputs ---
export INPUT_ROOT="/path/to/GLAN/PHASE1/spatial_temporal_merge"
export OUTPUT_ROOT="/path/to/GLAN_processed"

# Task directory (persistent; avoid /tmp which may be cleared on reboot)
export SHADOWMAP_TASK_ROOT="${OUTPUT_ROOT}/_shadowmap_tasks"
# Optional: override which bucket directory a script consumes.
# If unset, scripts pick sensible defaults under $SHADOWMAP_TASK_ROOT.
# export BUCKET_DIR="${SHADOWMAP_TASK_ROOT}/buckets_part1_migrated"

# Optional: backup dir used by recompute scripts
export BACKUP_DIR="${OUTPUT_ROOT}_backup"

# --- Buildings (local mode recommended for batch compute) ---
export BUILDING_SOURCE="local"
export BUILDING_LOCAL_GEOJSON="/path/to/buildings/hong_kong_cleaned.gpkg"
export BUILDING_GPKG_LAYER="hk_buildings"
export MOBILITY_BUILDINGS_MODE="preload" # bbox|preload

# --- Canopy (optional) ---
export SHADOW_ENGINE_CANOPY_RASTER_PATH="/path/to/Tree/HKtree_small.tif"

# --- ERA5 (optional but recommended for night fast-path) ---
export ERA5_FILE_TEMPLATE="/path/to/era5/era5_%Y%m_hk.nc"

# --- Node/HTTP pipeline (only if you still use the backend) ---
export BACKEND_URL="http://localhost:3001/api/analysis/shadow"
export WEATHER_URL="http://localhost:3001/api/weather/current"

# --- Tuning ---
# Recommended: pin BLAS threads to avoid oversubscription when using multiprocessing.
export OMP_NUM_THREADS="1"
export OPENBLAS_NUM_THREADS="1"
export MKL_NUM_THREADS="1"
export NUMEXPR_NUM_THREADS="1"

export CONC="16"           # bucket-level concurrency for incremental runner
export CONCURRENCY="96"    # bucket-level concurrency for full recompute batch runner
export MOBILITY_PROGRESS_STYLE="single"     # log|single
export MOBILITY_PROGRESS_INTERVAL="10"      # seconds (0 disables)
export MOBILITY_NIGHT_IRRADIANCE_THRESHOLD="1e-6"

# --- Backend (optional) ---
# WFS (buildings)
export BUILDING_WFS_BASE_URL="http://localhost:8080/geoserver/shadowmap/wfs"
export BUILDING_WFS_TYPE_NAME="shadowmap:buildings"

# DEM (GeoServer WMS)
export GEOSERVER_BASE_URL="http://localhost:8080/geoserver/shadowmap"
export GEOSERVER_DEM_LAYER="shadowmap:dem_munich"
