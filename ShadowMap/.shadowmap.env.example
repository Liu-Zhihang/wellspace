# ShadowMap machine profile (example)
#
# Usage:
# - Copy to `ShadowMap/.shadowmap.env` (kept local, gitignored), then run scripts normally.
# - Or keep multiple profiles elsewhere and export `SHADOWMAP_ENV_FILE=/path/to/profile.env`.
# - To skip loading any profile (useful when overriding env vars ad-hoc), set `SHADOWMAP_ENV_FILE=/dev/null`.
#
# This file is designed to unify paths and service URLs across machines (e.g. workstation vs server).
#
# NOTE:
# - Do NOT commit `ShadowMap/.shadowmap.env` with real local paths or credentials.

# --- Recommended dataset layout ---
# Keep project-facing data under one root so paths stay readable across machines.
# Example:
#   /datasets/wellspace_v2/shadowmap/
#     raw/glan/PHASE1/spatial_temporal_merge
#     derived/GLAN_processed_recalc_migrated_part1
#     infra/buildings/hong_kong_cleaned.geojson
#     infra/canopy/HKtree_small.tif
#     infra/weather/era5/era5_%Y%m_hk.nc
export SHADOWMAP_DATA_ROOT="/path/to/datasets/wellspace_v2/shadowmap"

# --- Mobility batch inputs/outputs ---
export INPUT_ROOT="${SHADOWMAP_DATA_ROOT}/raw/glan/PHASE1/spatial_temporal_merge"
export OUTPUT_ROOT="${SHADOWMAP_DATA_ROOT}/derived/GLAN_processed_recalc_migrated_part1"

# Task directory (persistent; avoid /tmp which may be cleared on reboot)
export SHADOWMAP_TASK_ROOT="${OUTPUT_ROOT}/_shadowmap_tasks"
# Optional: override which bucket directory a script consumes.
# If unset, scripts pick sensible defaults under $SHADOWMAP_TASK_ROOT.
# export BUCKET_DIR="${SHADOWMAP_TASK_ROOT}/buckets_part1_migrated"

# Optional: backup dir used by recompute scripts
export BACKUP_DIR="${OUTPUT_ROOT}_backup"

# --- Buildings ---
# `local` + GeoJSON is convenient for offline batch runs.
# On service hosts with city-scale datasets, prefer `BUILDING_SOURCE="wfs"`
# so the Node backend does not attempt to read a multi-GB GeoJSON into memory.
export BUILDING_SOURCE="local"
export BUILDING_LOCAL_GEOJSON="${SHADOWMAP_DATA_ROOT}/infra/buildings/hong_kong_cleaned.geojson"
export BUILDING_GPKG_LAYER="hk_buildings"
export MOBILITY_BUILDINGS_SOURCE="file" # file|postgis
export MOBILITY_BUILDINGS_MODE="preload" # bbox|preload; preload is file-only
# For national-scale offline runs, prefer direct PostGIS instead of WFS/GeoJSON:
# export SHADOWMAP_PYTHON_BIN="/home/jinlin/miniconda3/envs/pyshadow/bin/python3.11"
# export MOBILITY_BUILDINGS_SOURCE="postgis"
# export MOBILITY_POSTGIS_HOST="127.0.0.1"
# export MOBILITY_POSTGIS_PORT="5432"
# export MOBILITY_POSTGIS_DATABASE="shadowmap_gis"
# export MOBILITY_POSTGIS_USER="gisuser"
# export MOBILITY_POSTGIS_TABLE="public.buildings_us_lod1"
# export MOBILITY_POSTGIS_GEOM_COLUMN="geom"
# export MOBILITY_POSTGIS_HEIGHT_COLUMN="height"
# export MOBILITY_POSTGIS_WHERE="region IN ('USA','PRI','VIR')"
# export MOBILITY_GROUPING_MODE="run-cell-minute"
# export MOBILITY_CELL_SIZE_M="250"
# export MOBILITY_CELL_CONTEXT_M="800"
# export MOBILITY_SHADOW_CACHE_CELL_SIZE_M="1000"
# export MOBILITY_SHADOW_CACHE_MAX_ENTRIES="256"
# For sparse nationwide trajectories on wsA, benchmarked faster settings were much larger:
# - 3000m: exact-match output on the sample, faster than 250m
# - 12000m: exact-match output on the sample, fastest among tested sizes
# Start with large cells for US-wide sparse samples, but re-benchmark before making it global.
# export MOBILITY_GROUPING_MODE="run-cell-minute"
# export MOBILITY_CELL_SIZE_M="12000"
# export MOBILITY_CELL_CONTEXT_M="800"
# export MOBILITY_SHADOW_CACHE_CELL_SIZE_M="0"
# export MOBILITY_SHADOW_CACHE_MAX_ENTRIES="0"

# Optional speed-ups (preload mode only):
# When a 1-minute bucket contains points scattered across the city, its bbox can become huge and very slow.
# This enables selecting buildings/canopy by union of per-point buffers instead of the full bbox.
# Tune conservatively first (e.g. buffer 500m, threshold 2000m).
export MOBILITY_BUILDINGS_POINT_BUFFER_M="0"
export MOBILITY_BUILDINGS_POINT_BUFFER_THRESHOLD_M="0"

# --- Canopy (optional) ---
export SHADOW_ENGINE_CANOPY_RASTER_PATH="${SHADOWMAP_DATA_ROOT}/infra/canopy/HKtree_small.tif"
export MOBILITY_INCLUDE_CANOPY="true" # set to "false" for faster runs (buildings-only)

# --- ERA5 (optional but recommended for night fast-path) ---
export ERA5_FILE_TEMPLATE="${SHADOWMAP_DATA_ROOT}/infra/weather/era5/era5_%Y%m_hk.nc"

# --- Canonical service origins ---
# Keep these as the single source of truth for frontend, backend, worker, WFS, and scripts.
export SHADOWMAP_BACKEND_ORIGIN="http://localhost:3001"
export SHADOWMAP_ENGINE_ORIGIN="http://localhost:9000"
export SHADOWMAP_GEOSERVER_ORIGIN="http://localhost:8080/geoserver/shadowmap"
export SHADOWMAP_FRONTEND_HOST="0.0.0.0"
export SHADOWMAP_FRONTEND_PORT="5173"
export SHADOWMAP_ENABLE_DB="false"
export PORT="3001"
export CORS_ORIGINS="http://localhost:3000,http://localhost:5173"

# --- Node/HTTP pipeline ---
export SHADOW_ENGINE_BASE_URL="${SHADOWMAP_ENGINE_ORIGIN}"
export SHADOW_ENGINE_BACKEND_URL="${SHADOWMAP_BACKEND_ORIGIN}"
export BACKEND_URL="${SHADOWMAP_BACKEND_ORIGIN}/api/analysis/shadow"
export WEATHER_URL="${SHADOWMAP_BACKEND_ORIGIN}/api/weather/current"
export VITE_BACKEND_BASE_URL="${SHADOWMAP_BACKEND_ORIGIN}"
export VITE_CANOPY_RASTER_PATH="${SHADOW_ENGINE_CANOPY_RASTER_PATH}"

# --- Tuning ---
# Recommended: pin BLAS threads to avoid oversubscription when using multiprocessing.
export OMP_NUM_THREADS="1"
export OPENBLAS_NUM_THREADS="1"
export MKL_NUM_THREADS="1"
export NUMEXPR_NUM_THREADS="1"

export CONC="16"           # bucket-level concurrency for incremental runner
export CONCURRENCY="96"    # bucket-level concurrency for full recompute batch runner
export MOBILITY_PROGRESS_STYLE="single"     # log|single
export MOBILITY_PROGRESS_INTERVAL="10"      # seconds (0 disables)
export MOBILITY_NIGHT_IRRADIANCE_THRESHOLD="1e-6"

# --- Coordinate policy ---
# Mobility input coordinate columns can be noisy (especially `fnl_*` in some datasets).
# Configure a comma-separated priority list. Supported tokens:
# - gps, fnl, gpx, air
# - stay_point (uses stay_point_x/y only when stay_status>=1)
# - lnglat (uses lng/lat), lonlat (uses lon/lat)
export MOBILITY_COORD_PRIORITY="fnl,gps,gpx,air,lnglat"
# Indoor post-processing can use a different priority; default prefers stay-point centers when available.
export MOBILITY_INDOOR_COORD_PRIORITY="stay_point,fnl,gps,gpx,air,lnglat"
# Optional: expand building footprints during indoor masking (meters, approximate in EPSG:4326).
export MOBILITY_INDOOR_BUILDINGS_BUFFER_M="0"

# --- Trajectory continuity cleaning (post-process) ---
# Used by `ShadowMap/scripts/trajectory_clean_sunlight_csv.py` to drop teleport/jitter points.
export MOBILITY_CLEAN_COORD_PRIORITY="stay_point,fnl,gps,gpx,air,lnglat"
export MOBILITY_CLEAN_MAX_SPEED_KMH="200"
export MOBILITY_CLEAN_MAX_GAP_S="600"
export MOBILITY_CLEAN_MIN_SEGMENT_MIN="5"

# Cloud attenuation for `sunlightFactor` (used by `sunlitEffective = sunlit * sunlightFactor`)
# Default behavior: `sunlightFactor = max(min, 1 - coef*tcc)` where `tcc` is ERA5 total cloud cover (0..1).
# Sensitivity test: set MIN to 0 to remove the 0.15 floor.
export MOBILITY_SUNLIGHT_FACTOR_MIN="0.15"
export MOBILITY_SUNLIGHT_FACTOR_COEF="0.85"

# --- Backend (optional) ---
# WFS (buildings)
export BUILDING_WFS_BASE_URL="${SHADOWMAP_GEOSERVER_ORIGIN}/wfs"
export BUILDING_WFS_TYPE_NAME="shadowmap:buildings"
# Optional for large coverages such as `public.buildings_us_lod1`:
# export BUILDING_WFS_TILE_CATALOG_PATH="./config/buildingTiles.us_lod1.json"
# export BUILDING_WFS_TILE_STRATEGY="required"

# DEM (GeoServer WMS)
export GEOSERVER_BASE_URL="${SHADOWMAP_GEOSERVER_ORIGIN}"
export GEOSERVER_DEM_LAYER="shadowmap:dem_munich"
