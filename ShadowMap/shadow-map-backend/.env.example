# Server Configuration
PORT=3001
NODE_ENV=development

# DEM Data Configuration
DEM_CACHE_DIR=./data/cache
DEM_MAX_ZOOM=15
DEM_TILE_SIZE=256

# API Configuration
API_RATE_LIMIT=1000
CORS_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=info

# WFS Configuration
# Optional GeoServer configuration
# BUILDING_WFS_BASE_URL=http://localhost:8080/geoserver/shadowmap/wfs
# BUILDING_WFS_TYPE_NAME=shadowmap:buildings
# BUILDING_WFS_VERSION=1.1.0
# BUILDING_WFS_ASCII=true
# BUILDING_WFS_TILE_CATALOG_PATH=./config/buildingTiles.json
# BUILDING_WFS_TILE_STRATEGY=optional

# Local buildings (optional, skip WFS and read local GeoJSON)
# BUILDING_SOURCE=local
# BUILDING_LOCAL_GEOJSON=/path/to/buildings.geojson

# ERA5 (optional, used by /api/weather/current)
# ERA5_FILE_TEMPLATE=/path/to/era5/era5_%Y%m_hk.nc
# ERA5_FILE_PATH=/path/to/era5/era5_202111_hk.nc
# ERA5_PYTHON_BIN=python3
# ERA5_PYTHON_SCRIPT=../scripts/era5_extract.py
