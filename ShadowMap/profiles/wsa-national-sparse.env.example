# wsA nationwide offline profile (example)
#
# Copy this to a local-only file such as:
#   ShadowMap/.shadowmap.wsa-national.env
# Then run:
#   export SHADOWMAP_ENV_FILE=/path/to/ShadowMap/.shadowmap.wsa-national.env
#   ./scripts/ops/run_mobility_shadow_sharded.sh ...
#
# This profile is for production-style offline mobility shadow runs on wsA.
# It intentionally bypasses WFS/HTTP for buildings and prepares canopy locally
# per shard. Keep credentials out of git; use the local socket auth path on wsA.

export SHADOWMAP_DATA_ROOT="${HOME}/datasets/wellspace_v2/shadowmap"
export SHADOWMAP_PYTHON_BIN="${HOME}/miniconda3/envs/pyshadow/bin/python3.11"
export PROJ_DATA="${HOME}/miniconda3/envs/pyshadow/share/proj"
export PROJ_LIB="${HOME}/miniconda3/envs/pyshadow/share/proj"
export GDAL_DATA="${HOME}/miniconda3/envs/pyshadow/share/gdal"

export INPUT_ROOT="${HOME}/data/Mobility_Data"
export OUTPUT_ROOT="${SHADOWMAP_DATA_ROOT}/derived/mobility_shadow_runs"
export SHADOWMAP_TASK_ROOT="${OUTPUT_ROOT}/_shadowmap_tasks"

export MOBILITY_RUNNER_PRESET="national-sparse"
export MOBILITY_SHARD_STRATEGY="spatial"
export MOBILITY_SPATIAL_SHARD_BIN_DEG="2.0"
export MOBILITY_BUILDINGS_SOURCE="postgis"
export MOBILITY_BUILDINGS_MODE="bbox"
export MOBILITY_POSTGIS_DATABASE="shadowmap_gis"
export MOBILITY_POSTGIS_USER="jinlin"
export MOBILITY_POSTGIS_TABLE="public.buildings_us_lod1"
export MOBILITY_POSTGIS_GEOM_COLUMN="geom"
export MOBILITY_POSTGIS_HEIGHT_COLUMN="height"

export ERA5_FILE_TEMPLATE="${SHADOWMAP_DATA_ROOT}/infra/weather/era5/global/era5_%Y%m.nc"

export MOBILITY_INCLUDE_CANOPY="true"
export MOBILITY_CANOPY_AUTO_PREP="true"
export MOBILITY_CANOPY_PREFETCH_MODE="union"
export MOBILITY_CANOPY_SOURCE="global"
export MOBILITY_CANOPY_CACHE_DIR="/mnt/data_hdd/shadowmap_cache/meta_wri_chm/raw_tiles/global"
export MOBILITY_CANOPY_TILES_INDEX="${SHADOWMAP_DATA_ROOT}/infra/canopy/meta_wri_chm/index/tiles.geojson"
export MOBILITY_CANOPY_DOWNLOAD_JOBS="8"
export MOBILITY_CANOPY_BBOX_MARGIN_M="800"

export OMP_NUM_THREADS="1"
export OPENBLAS_NUM_THREADS="1"
export MKL_NUM_THREADS="1"
export NUMEXPR_NUM_THREADS="1"
